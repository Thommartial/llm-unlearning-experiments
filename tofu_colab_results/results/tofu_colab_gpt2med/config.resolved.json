{
  "name": "tofu_colab_gpt2med",
  "seed": 42,
  "output_dir": "results",
  "device": "auto",
  "model": {
    "name": "gpt2-medium",
    "dtype": "float32"
  },
  "data": {
    "dataset": "tofu",
    "forget_fraction": 0.1,
    "holdout_fraction": 0.2,
    "max_samples": null,
    "max_length": 128,
    "n_synthetic": 240,
    "seq_len": 32,
    "vocab_size": 256,
    "outlier_fraction": 0.3
  },
  "unlearn": {
    "method": "npo",
    "epochs": 2,
    "finetune_epochs": 4,
    "learning_rate": 1e-05,
    "finetune_lr": 2e-05,
    "batch_size": 4,
    "retain_weight": 1.0,
    "beta": 0.1
  },
  "attack": {
    "method": "min_k_prob",
    "min_k": 0.2
  }
}